{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"outDir": "out",
		"rootDir": "src",
		"lib": [
			"es6"
		],
		"types": [
			"vscode",
			"node",
			"mocha"
		],
		"sourceMap": true,
		"strict": false,
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules"
	],
}