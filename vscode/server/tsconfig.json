{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"skipLibCheck": true,
		"target": "es2020",
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"outDir": "out",
		"rootDir": "src",
		"typeRoots": ["../node_modules/@types"],
		"types": ["node"],
		"lib": [ "es2020", "DOM", "DOM.Iterable" ]
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules"
	]
}